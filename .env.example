# DrChrono OAuth2
DRCHRONO_CLIENT_ID=your_client_id
DRCHRONO_CLIENT_SECRET=your_client_secret
DRCHRONO_REDIRECT_URI=http://localhost:8080/callback

# DrChrono scheduling config (auto-discovered by auth_drchrono.py)
DRCHRONO_DOCTOR_ID=
DRCHRONO_OFFICE_ID=
DRCHRONO_EXAM_ROOM=

# Google Calendar — comma-separated list of calendar IDs to sync
# Use "primary" for your main calendar. Find other IDs in Google Calendar settings.
GOOGLE_CALENDAR_IDS=primary

# All-day events — only sync all-day events whose title contains one of these
# keywords (case-insensitive, comma-separated)
ALLDAY_KEYWORDS=vacation,out of office,off,block,pto,travel

# Business hours for all-day blocks (HH:MM, 24h format)
ALLDAY_BLOCK_START=08:00
ALLDAY_BLOCK_END=18:00

# Sync window (months ahead to sync)
SYNC_WINDOW_MONTHS=6
